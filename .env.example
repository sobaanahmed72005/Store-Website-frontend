# Copy to .env and adjust for your environment. Never commit .env itself.
#
# Everything here is prefixed VITE_ and gets baked into the public JS bundle at build time — do
# not put real secrets behind a VITE_ variable (see DEPLOYMENT.md).

# Backend API base URL.
VITE_API_URL=http://localhost:5000/api

# Optional: override the obfuscated admin panel path (see src/config/adminPath.js).
# Must start with "/", no trailing slash. Obscurity only — not a substitute for auth.
# Must match ADMIN_PATH in the backend's own .env.
VITE_ADMIN_PATH=/mgmt-8f2k1c

# Optional: only read by e2e/auth.spec.js, for a real admin sign-in round trip against a running
# backend. Tests that need these skip gracefully if unset — never commit real values here.
E2E_ADMIN_EMAIL=
E2E_ADMIN_PASSWORD=
